<MudDialog>
    <DialogContent>
        <div class="d-flex align-center justify-space-between">
            <div class="left-side">
                @if (ItemId is null)
                {
                    <MudText Typo="Typo.h6">Add Item</MudText>
                }
                else
                {
                    <MudText Typo="Typo.h6">Edit Item</MudText>
                }
            </div>

            <div class="right-side">
                <MudIconButton Icon="@Icons.Material.Filled.Close"
                               Color="Color.Default"
                               Variant="Variant.Text"
                               OnClick="Cancel" />
            </div>
        </div>

        <MudForm @ref="_form">
            <MudGrid Spacing="6">

                <MudItem xs="12">
                    <MudTextField @bind-Value="Item.Name"
                                  Label="Name"
                                  Required
                                  MaxLength="10"
                                  RequiredError="Name is required" />
                </MudItem>

                <MudItem xs="12">
                    <MudSelect T="M.ItemType"
                               Required
                               @bind-Value="Item.Type"
                               Label="Type">
                        @foreach (var status in Enum.GetValues<M.ItemType>())
                        {
                            <MudSelectItem Value="status">@status</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12">
                    <MudNumericField T="decimal"
                                     Format="@UltilityAssets.DecimalFormat"
                                     @bind-Value="Item.Price"
                                     Label="Price"
                                     Required
                                     Min="0" />
                </MudItem>

                <MudItem>
                    <MudSwitch LabelPlacement="Placement.Top" Label="Inactive" @bind-Value="Item.InActive"
                               Color="Color.Error" />
                </MudItem>



            </MudGrid>
        </MudForm>

        <MudButton Variant="Variant.Filled" Class="core-bg-color float-right w-200px"
                   OnClick="Save">
            <MudText Class="text-white">Save</MudText>
        </MudButton>

    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter]
    public IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public int? ItemId { get; set; }
    private M.Item Item { get; set; } = new();

    private MudForm _form = default!;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await GetData();
            await InvokeAsync(StateHasChanged);
        }
        await base.OnAfterRenderAsync(firstRender);
    }


    private async Task GetData()
    {
        try
        {
            if (ItemId is not null)
            {
                var param = new M.IdParam() { Id = ItemId ?? 0, VenueId = 4 };
                Item = await ItemAPI.GetByIdAsync(param) ?? new M.Item();
            }
            else
            {
                Item = new();
                Item.Type = M.ItemType.Inventory;
                Item.InActive = false;
                Item.VenueId = 4;
            }
        }
        catch (Exception ex)
        {
            await MessageDialogService.ShowError("ItemEntry.21211", ex.Message);
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task Save()
    {
        await _form.Validate();

        if (!_form.IsValid)
            return;

        MudDialog.Close(DialogResult.Ok(Item));
    }
}


